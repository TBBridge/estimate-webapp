# --- Neon Postgres（必須: 代理店登録・見積保存など）---
# Vercel で Neon を接続すると DATABASE_URL または POSTGRES_URL が付与されることがあります（どちらかがあれば可）
# DATABASE_URL=postgres://...
# POSTGRES_URL=postgres://...

# --- kintone（見積フォーム「ライセンス追加」「オプション追加」から既存情報取得） ---
# ドメイン（末尾スラッシュなし推奨）
KINTONE_DOMAIN=https://dea5gs2qu9n6.cybozu.com
# ライセンス参照アプリの ID（変更時はここを更新。未設定時は 219）
KINTONE_APP_ID=219
# 上記アプリ用 API トークン（レコード閲覧・フォームフィールド参照）
KINTONE_API_TOKEN=
# 後方互換: KINTONE_APP_LICENSE=219 / KINTONE_API_TOKEN_APP219=（KINTONE_APP_ID・KINTONE_API_TOKEN が優先）

# フィールドコードは kintone アプリの「フィールドコード」と完全一致させる（日本語名ではない）
# 一覧確認: ブラウザで /api/kintone/app-fields （GAIA_IQ11 のときはここで code を確認）
# KINTONE_FIELD_AGENCY_ID=agency_id
# KINTONE_FIELD_CUSTOMER=customer_name
# KINTONE_FIELD_LICENSE=license_count
# KINTONE_FIELD_MAINT_START=maint_start
# KINTONE_FIELD_MAINT_END=maint_end

# 代理店の突合: id（DBの agencyId を kintone に格納）または name（DBの代理店名で一致）
# KINTONE_MATCH_AGENCY_BY=id

# 顧客名の検索: like（既定・部分一致）または equals（ドロップダウン等 like 不可のとき）
# KINTONE_CUSTOMER_MATCH_MODE=like
# 部分一致で返す最大件数（1〜100、既定 30）。複数件のときフォームで選択
# KINTONE_LOOKUP_MAX_RESULTS=30
# like モードで検索に使う最小文字数（既定 2）
# KINTONE_SEARCH_MIN_LENGTH=2

# --- kintone 営業案件管理アプリ（契約形態「新規」の見積を承認したときに upsert）---
# 未設定なら承認は従来どおり成功し、kintone 連携はスキップされます。
# KINTONE_SALES_APP_ID=
# 営業案件アプリ用 API トークン（必須権限の例: レコード閲覧・追加・編集）
# 同一顧客の 2 件目以降の承認では「レコードの更新」API を使うため「レコードの編集」が必須（未設定だと GAIA_NO01 / 403）
# KINTONE_SALES_API_TOKEN=
# 必須: 顧客名のフィールドコード（DB の customer_name と完全一致で既存レコードを検索）
# KINTONE_SALES_FIELD_CUSTOMER=
# upsert・詳細表示の検索範囲: customer（既定・顧客名のみで 1 レコード）または customer_and_agency（代理店+顧客）
# KINTONE_SALES_UPSERT_SCOPE=customer
# 代理店フィールド（書き込み用）。customer_and_agency のときは検索条件にも使う
# KINTONE_SALES_FIELD_AGENCY_ID=
# KINTONE_SALES_MATCH_AGENCY_BY=id
# 複数見積の追記用（長文・複数行）。承認のたびに 1 行追加。未設定なら履歴追記なし
# KINTONE_SALES_FIELD_ESTIMATE_HISTORY=
# 任意のマッピング（設定したフィールドだけ kintone に書き込み）
# KINTONE_SALES_FIELD_ESTIMATE_NO= / _AGENCY_NAME= / _AGENCY_ID= / _DELIVERY= / _CONTRACT=
# KINTONE_SALES_FIELD_DELIVERY_RAW= / _CONTRACT_RAW= / _CLOUD_BILLING=
# KINTONE_SALES_FIELD_EXCEL_URL= / _PDF_URL= / _WEB_ESTIMATE_ID=
# KINTONE_SALES_FIELD_AMOUNT= / _MAINTENANCE_FEE= / _APPROVED_AT=（DATE 用 YYYY-MM-DD）
# KINTONE_SALES_FIELD_FORM_JSON=（長文 JSON。文字数上限あり）

# --- HubSpot（Private App + CRM v3：見積申請時に取引を検索し、既存がなければ新規作成）---
# 未設定、または重複条件のみ不足のときは連携をスキップします（申請は成功します）。
# アクセストークン発行: HubSpot 左メニュー「開発（Development）」→「レガシーアプリ（Legacy apps）」
# →「レガシーアプリを作成」→ 種類で「プライベート（Private）」を選択。※スーパー管理者のみ。
# （旧 UI の「設定 → 統合 → プライベートアプリ」は廃止／移動済みのポートが多いです）
# スコープ例: crm.objects.deals.read、crm.objects.deals.write、crm.schemas.deals.read
# 取引担当者を氏名検索する場合: crm.objects.owners.read
# HUBSPOT_ACCESS_TOKEN=pat-na2-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 省略可。既定 https://api.hubapi.com
# HUBSPOT_API_BASE=https://api.hubapi.com
#
# 重複判定（どちらか一方）:
# (A) 単一カスタムプロパティに「agency_id|正規化顧客名」を格納して照合
#     HubSpot で単一行テキストのカスタムプロパティを作成し、その内部名を指定
# HUBSPOT_MATCH_PROPERTY=webapp_match_key
# (B) 代理店 ID と顧客名で AND 検索（各フィールドの内部名を指定）
# HUBSPOT_MATCH_AGENCY_PROPERTY=
# HUBSPOT_MATCH_CUSTOMER_PROPERTY=
#
# AND モード時、代理店プロパティに送る値（既定: name）
#   name … 見積の代理店名（HubSpot のドロップダウン選択肢と完全一致）
#   id   … DB の agency_id（UUID）。単一行テキストに ID を保存している場合のみ
# HUBSPOT_MATCH_AGENCY_SENDS=name
#
# ▼ HUBSPOT_MATCH_* に指定するのは「画面上のラベル」ではなく API 用の内部名です。
#    HubSpot: 設定 → データ管理 → プロパティ → 「取引のプロパティ」で対象フィールドを開き、
#    「内部名」（英数字とアンダースコアの id）をコピーしてください。
#    ラベルが「会社名」でも内部名は company_name や xxx_company など別名のことがほとんどです。
#    会社（会社オブジェクト）の「会社名」プロパティは取引検索の propertyName として使えません。
#    取引に会社名を載せるカスタム取引プロパティを作るか、未設定のまま dealname の部分一致検索に任せてください。
#
# パイプライン／ステージ（ID が最優先。無い場合は下記ラベルで API 解決）
# HUBSPOT_PIPELINE_ID=
# HUBSPOT_DEAL_STAGE_ID=
# HubSpot 画面上の名前と完全一致（例: パートナーパイプライン / C（180日以内））
# HUBSPOT_PIPELINE_LABEL=パートナーパイプライン
# HUBSPOT_DEAL_STAGE_LABEL=C（180日以内）
#
# 取引作成時の必須カスタム項目（内部名は HubSpot「取引のプロパティ」で確認）
# HUBSPOT_DEAL_PROPERTY_COMPANY_NAME=
# HUBSPOT_DEAL_PROPERTY_PREFECTURE=
# HUBSPOT_DEAL_PREFECTURE_VALUE=海外
# HUBSPOT_DEAL_PROPERTY_NEGOTIATION=
# 取引担当者: ID 直接指定が確実。未指定時は Owners API で氏名一致（要 crm.objects.owners.read）
# HUBSPOT_DEAL_OWNER_ID=
# HUBSPOT_DEAL_OWNER_SEARCH_NAME=YONGHU LU
# true のとき取引名 = 「見積番号 + 会社名」。未設定時は取引名＝会社名のみ
# HUBSPOT_DEAL_NAME_INCLUDE_ESTIMATE_NO=false
#
# 作成時に追加で送るプロパティ（JSON。{{estimate_no}} {{customer_name}} {{agency_id}} {{agency_name}} {{contract_type}} {{contract_type_label}}）
# HUBSPOT_CREATE_PROPERTIES_JSON={"hs_priority":"medium"}

# --- CloudConvert（Excel → PDF。/api/estimates/[id]/generate-pdf および Excel 差し替え後の再生成）---
# API キー: https://cloudconvert.com/dashboard/api/v2/keys
# 必須スコープ: task.read, task.write（片方だけ / user のみ だと 403 Invalid scope(s) になります。キー編集で有効化するか、新しいキーを発行）
# CLOUDCONVERT_API_KEY=
# 既定 https://sync.api.cloudconvert.com/v2/jobs（リージョン別 URL に差し替え可）
# CLOUDCONVERT_SYNC_URL=https://sync.api.cloudconvert.com/v2/jobs
# xlsx→pdf のエンジン: 未設定または office（既定）/ libreoffice / auto（engine 指定なし）
# CLOUDCONVERT_EXCEL_ENGINE=office
