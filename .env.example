# --- Neon Postgres（必須: 代理店登録・見積保存など）---
# Vercel で Neon を接続すると DATABASE_URL または POSTGRES_URL が付与されることがあります（どちらかがあれば可）
# DATABASE_URL=postgres://...
# POSTGRES_URL=postgres://...

# --- kintone（見積フォーム「ライセンス追加」「オプション追加」から既存情報取得） ---
# ドメイン（末尾スラッシュなし推奨）
KINTONE_DOMAIN=https://dea5gs2qu9n6.cybozu.com
# ライセンス参照アプリの ID（変更時はここを更新。未設定時は 219）
KINTONE_APP_ID=219
# 上記アプリ用 API トークン（レコード閲覧・フォームフィールド参照）
KINTONE_API_TOKEN=
# 後方互換: KINTONE_APP_LICENSE=219 / KINTONE_API_TOKEN_APP219=（KINTONE_APP_ID・KINTONE_API_TOKEN が優先）

# フィールドコードは kintone アプリの「フィールドコード」と完全一致させる（日本語名ではない）
# 一覧確認: ブラウザで /api/kintone/app-fields （GAIA_IQ11 のときはここで code を確認）
# KINTONE_FIELD_AGENCY_ID=agency_id
# KINTONE_FIELD_CUSTOMER=customer_name
# KINTONE_FIELD_LICENSE=license_count
# KINTONE_FIELD_MAINT_START=maint_start
# KINTONE_FIELD_MAINT_END=maint_end

# 代理店の突合: id（DBの agencyId を kintone に格納）または name（DBの代理店名で一致）
# KINTONE_MATCH_AGENCY_BY=id

# 顧客名の検索: like（既定・部分一致）または equals（ドロップダウン等 like 不可のとき）
# KINTONE_CUSTOMER_MATCH_MODE=like
# 部分一致で返す最大件数（1〜100、既定 30）。複数件のときフォームで選択
# KINTONE_LOOKUP_MAX_RESULTS=30
# like モードで検索に使う最小文字数（既定 2）
# KINTONE_SEARCH_MIN_LENGTH=2

# --- kintone 営業案件管理アプリ（契約形態「新規」の見積を承認したときに upsert）---
# 未設定なら承認は従来どおり成功し、kintone 連携はスキップされます。
# KINTONE_SALES_APP_ID=
# 営業案件アプリ用 API トークン（必須権限の例: レコード閲覧・追加・編集）
# 同一顧客の 2 件目以降の承認では「レコードの更新」API を使うため「レコードの編集」が必須（未設定だと GAIA_NO01 / 403）
# KINTONE_SALES_API_TOKEN=
# 必須: 顧客名のフィールドコード（DB の customer_name と完全一致で既存レコードを検索）
# KINTONE_SALES_FIELD_CUSTOMER=
# upsert・詳細表示の検索範囲: customer（既定・顧客名のみで 1 レコード）または customer_and_agency（代理店+顧客）
# KINTONE_SALES_UPSERT_SCOPE=customer
# 代理店フィールド（書き込み用）。customer_and_agency のときは検索条件にも使う
# KINTONE_SALES_FIELD_AGENCY_ID=
# KINTONE_SALES_MATCH_AGENCY_BY=id
# 複数見積の追記用（長文・複数行）。承認のたびに 1 行追加。未設定なら履歴追記なし
# KINTONE_SALES_FIELD_ESTIMATE_HISTORY=
# 任意のマッピング（設定したフィールドだけ kintone に書き込み）
# KINTONE_SALES_FIELD_ESTIMATE_NO= / _AGENCY_NAME= / _AGENCY_ID= / _DELIVERY= / _CONTRACT=
# KINTONE_SALES_FIELD_DELIVERY_RAW= / _CONTRACT_RAW= / _CLOUD_BILLING=
# KINTONE_SALES_FIELD_EXCEL_URL= / _PDF_URL= / _WEB_ESTIMATE_ID=
# KINTONE_SALES_FIELD_AMOUNT= / _MAINTENANCE_FEE= / _APPROVED_AT=（DATE 用 YYYY-MM-DD）
# KINTONE_SALES_FIELD_FORM_JSON=（長文 JSON。文字数上限あり）
